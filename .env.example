# DNAcloud Server 环境变量模板
# 复制此文件为 .env，填写所有 <REPLACE_ME> 项

# ─── 服务基础 ────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# 服务公网地址（artifact 下载链接前缀，必须填写）
DNACLOUD_BASE_URL=https://<REPLACE_ME>

# ─── 数据库 ──────────────────────────────────────────────────────────────────
# 开发/演示用 H2（默认，无需额外配置）
# DB_URL=jdbc:h2:file:./data/dnacloud;DB_CLOSE_ON_EXIT=FALSE
# DB_DRIVER=org.h2.Driver
# DB_USERNAME=sa
# DB_PASSWORD=

# 生产用 MySQL（先运行 scripts/setup-mysql.sh）
# DB_URL=jdbc:mysql://127.0.0.1:3306/dnacloud?useSSL=false&serverTimezone=UTC&characterEncoding=utf8mb4
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_USERNAME=dnacloud
# DB_PASSWORD=<REPLACE_ME>
# JPA_DDL_AUTO=validate
# JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# ─── Artifact 存储 ───────────────────────────────────────────────────────────
DNACLOUD_ARTIFACT_STORE=/opt/dnacloud/artifacts

# ─── Solana 支付配置 ─────────────────────────────────────────────────────────
# 平台 Solana 收款地址（接收买家 USDC 付款）
DNACLOUD_MERCHANT_ADDRESS=AY5669hoJZMxWnaUGtbefiRj4btzXX5iR8Kh9Mtnc4KV

# Solana RPC 节点（默认 devnet，生产改为 mainnet-beta）
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=solana-devnet

# USDC Mint 地址
# Devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ─── 平台出款（可选）────────────────────────────────────────────────────────
# 配置后 payout worker 可自动向创作者 Solana 地址结算
# 不配置时 payout 保持 pending 状态，需手动处理
# DNACLOUD_TREASURY_KEY=<REPLACE_ME>

# ─── 安全密钥 ────────────────────────────────────────────────────────────────
# Admin API Key（保护 /v1/creator/admin/* 端点，建议 32+ 字符随机字符串）
DNACLOUD_ADMIN_API_KEY=<REPLACE_ME>

# 包签名密钥（对上传 artifact 进行 HMAC 签名）
DNACLOUD_SIGNING_KEY=<REPLACE_ME>

# ─── 业务参数 ────────────────────────────────────────────────────────────────
DNACLOUD_CORS_ORIGINS=https://<REPLACE_ME>
DNACLOUD_PLATFORM_FEE_RATE=0.20
DNACLOUD_MINIMUM_PAYOUT=100000

# ─── 开发调试（生产必须保持注释或 false）────────────────────────────────────
# DNACLOUD_LOCAL_TEST=false    # true 时跳过支付验证，禁止在生产开启
