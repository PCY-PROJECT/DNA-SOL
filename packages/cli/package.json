{
  "name": "soldnacloud",
  "version": "0.7.5",
  "type": "module",
  "description": "DNAcloud CLI — install expert DNA capabilities into Claude Code",
  "bin": {
    "dnacloud-sol": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "bootstrap/"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-bootstrap.js",
    "dev": "tsc --watch",
    "test": "node --test dist/**/*.test.js",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@soldnacloud/schema": "^1.0.1",
    "@soldnacloud/validator": "^0.6.2",
    "adm-zip": "^0.5.16",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
