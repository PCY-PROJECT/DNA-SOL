{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__order-execution__(place_order|cancel_order|modify_order)|mcp__wallet__(swap|approve)",
        "hooks": [
          {
            "type": "command",
            "command": "node .dnacloud/hooks/trade-guard.js"
          }
        ]
      }
    ]
  }
}
